local function TLIUGW_fake_script() -- SetSpawnButton.LocalScript 
	local script = Instance.new('LocalScript', SetSpawnButton)

	local button = script.Parent
	local Players = game:GetService("Players")
	local player = Players.LocalPlayer
	
	local stuckEnabled = false
	local stuckPosition = nil
	local loopConnection = nil
	
	local function startStuckLoop()
		if loopConnection then
			loopConnection:Disconnect()
		end
	
		loopConnection = game:GetService("RunService").Heartbeat:Connect(function()
			if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
				player.Character:MoveTo(stuckPosition)
			end
		end)
	end
	
	
	local function onCharacterAdded(character)
		if stuckEnabled and stuckPosition then
	
			character:WaitForChild("HumanoidRootPart")
			startStuckLoop()
		end
	end
	
	local function toggleStuck()
		stuckEnabled = not stuckEnabled
	
		if stuckEnabled then
			button.Text = "SetSpawn"
	
	
			local char = player.Character
			if char and char:FindFirstChild("HumanoidRootPart") then
				stuckPosition = char.HumanoidRootPart.Position
				startStuckLoop()
			end
	
			player.CharacterAdded:Connect(onCharacterAdded)
		else
			button.Text = "SetSpawn"
			stuckPosition = nil
			if loopConnection then
				loopConnection:Disconnect()
				loopConnection = nil
			end
		end
	end
	
	button.MouseButton1Click:Connect(toggleStuck)
	
end
