local function MLAOQ_fake_script() -- AutoResetButton.LocalScript 
	local script = Instance.new('LocalScript', AutoResetButton)

	local button = script.Parent
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	
	local player = Players.LocalPlayer
	
	-- Auto Reset and Stuck System
	local autoResetEnabled = false
	local connection
	local characterAddedConnection
	
	-- Stuck system variables
	local stuckPosition = nil
	local loopConnection = nil
	
	------------------------------------------------
	-- Helper Functions
	------------------------------------------------
	
	-- Freeze player movement
	local function disableMovement()
		local character = player.Character
		if not character then return end
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			humanoid.WalkSpeed = 0
			humanoid.JumpPower = 0
		end
	end
	
	-- Restore player movement
	local function enableMovement()
		local character = player.Character
		if not character then return end
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			humanoid.WalkSpeed = 16
			humanoid.JumpPower = 50
		end
	end
	
	-- Start Stuck Loop (keeps player at same position)
	local function startStuckLoop()
		if loopConnection then
			loopConnection:Disconnect()
		end
	
		loopConnection = RunService.Heartbeat:Connect(function()
			if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and stuckPosition then
				player.Character:MoveTo(stuckPosition)
			end
		end)
	end
	
	-- Stop the stuck loop
	local function stopStuckLoop()
		if loopConnection then
			loopConnection:Disconnect()
			loopConnection = nil
		end
	end
	
	------------------------------------------------
	-- Main AutoReset + Stuck Toggle
	------------------------------------------------
	local function toggleAutoReset()
		autoResetEnabled = not autoResetEnabled
	
		if autoResetEnabled then
			button.Text = "AutoReset: ON"
	
			-- Save player position when activated
			local char = player.Character
			if char and char:FindFirstChild("HumanoidRootPart") then
				stuckPosition = char.HumanoidRootPart.Position
				startStuckLoop()
			end
	
			-- Function to handle humanoid setup
			local function setupHumanoid(humanoid)
				if connection then
					connection:Disconnect()
				end
	
				connection = humanoid.HealthChanged:Connect(function(health)
					if autoResetEnabled and health < humanoid.MaxHealth then
						-- Instantly kill (auto-reset)
						humanoid.Health = 0
						disableMovement()
					end
				end)
	
				humanoid.Died:Connect(function()
					disableMovement()
				end)
			end
	
			-- Setup current character
			if player.Character then
				local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
				if humanoid then
					setupHumanoid(humanoid)
				end
			end
	
			-- Handle respawn
			if characterAddedConnection then
				characterAddedConnection:Disconnect()
			end
	
			characterAddedConnection = player.CharacterAdded:Connect(function(char)
				local humanoid = char:WaitForChild("Humanoid")
				local root = char:WaitForChild("HumanoidRootPart")
	
				------------------------------------------------
				-- 🧊 NEW SECTION: Freeze on reset, then unfreeze
				------------------------------------------------
				task.wait(0.5)
				stuckPosition = root.Position
				disableMovement()
				startStuckLoop()
	
				-- Auto-unfreeze after a few seconds
				local freezeDuration = 3 -- ⏳ Change this number if you want longer/shorter freeze
				task.delay(freezeDuration, function()
					stopStuckLoop()
					enableMovement()
				end)
				------------------------------------------------
	
				setupHumanoid(humanoid)
			end)
	
		else
			button.Text = "AutoReset: OFF"
	
			-- Disconnect everything
			if connection then
				connection:Disconnect()
				connection = nil
			end
			if characterAddedConnection then
				characterAddedConnection:Disconnect()
				characterAddedConnection = nil
			end
	
			stuckPosition = nil
			stopStuckLoop()
			enableMovement()
		end
	end
	
	------------------------------------------------
	-- Setup Button
	------------------------------------------------
	button.MouseButton1Click:Connect(toggleAutoReset)
	button.Text = "AutoReset: OFF"
	
end
