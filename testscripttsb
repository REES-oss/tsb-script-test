		tween:Play()
		tween.Completed:Connect(function()
			frame.Visible = false
		end)
	end
	
	-- toggle on button click
	local isVisible = false
	button.MouseButton1Click:Connect(function()
		isVisible = not isVisible
		if isVisible then
			fadeIn()
		else
			fadeOut()
		end
	end)
	
end
