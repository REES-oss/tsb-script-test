local function GNDRE_fake_script() -- ImageButton.LocalScript 
	local script = Instance.new('LocalScript', ImageButton)

	
	
	local TweenService = game:GetService("TweenService")
	
	-- UI references
	local imageButton = script.Parent
	local screenGui = imageButton.Parent
	local mainFrame = screenGui:WaitForChild("ScriptFrame")
	
	-- Sounds
	local hoverSound = imageButton:FindFirstChild("HoverSound")
	local clickSound = imageButton:FindFirstChild("ClickSound")
	
	-- Initial states
	mainFrame.Visible = false
	mainFrame.BackgroundTransparency = 1
	
	-- Tween settings
	local tweenInfo = TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local hoverTweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	
	-- // Hover effect
	imageButton.MouseEnter:Connect(function()
		-- Play hover sound
		if hoverSound then hoverSound:Play() end
	
		-- Slightly shrink and dim the image
		local shrinkTween = TweenService:Create(imageButton, hoverTweenInfo, {
			Size = imageButton.Size - UDim2.new(0, 4, 0, 4),
			ImageColor3 = Color3.fromRGB(200, 200, 200)
		})
		shrinkTween:Play()
	end)
	
	-- // Mouse leaves (reset hover)
	imageButton.MouseLeave:Connect(function()
		local resetTween = TweenService:Create(imageButton, hoverTweenInfo, {
			Size = imageButton.Size + UDim2.new(0, 4, 0, 4),
			ImageColor3 = Color3.fromRGB(255, 255, 255)
		})
		resetTween:Play()
	end)
	
	-- // Click effect (fade in frame + click sound)
	imageButton.MouseButton1Click:Connect(function()
		-- Play click sound
		if clickSound then clickSound:Play() end
	
		-- Hide the button
		imageButton.Visible = false
	
		-- Make frame visible so it can fade in
		mainFrame.Visible = true
	
		-- Fade in the frame
		local fadeInTween = TweenService:Create(mainFrame, tweenInfo, {BackgroundTransparency = 0})
		fadeInTween:Play()
	
		-- Fade in all UI elements inside
		for _, object in pairs(mainFrame:GetDescendants()) do
			if object:IsA("TextLabel") or object:IsA("TextButton") or object:IsA("ImageLabel") or object:IsA("ImageButton") then
				object.BackgroundTransparency = 1
				if object:IsA("TextLabel") or object:IsA("TextButton") then
					object.TextTransparency = 1
				end
	
				local props = {BackgroundTransparency = 0}
				if object:IsA("TextLabel") or object:IsA("TextButton") then
					props.TextTransparency = 0
				end
	
				local tween = TweenService:Create(object, tweenInfo, props)
				tween:Play()
			end
		end
	end)
	
end
