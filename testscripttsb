local function NTZVIZ_fake_script() -- AutoClaimButton.LocalScript 
	local script = Instance.new('LocalScript', AutoClaimButton)

	
	local button = script.Parent
	local Players = game:GetService("Players")
	local player = Players.LocalPlayer
	
	--// Function to find GUI elements safely
	local function getSpinButton()
		local playerGui = player:FindFirstChild("PlayerGui")
		if not playerGui then return nil end
	
		local emotesGui = playerGui:FindFirstChild("Emotes")
		if not emotesGui then return nil end
	
		local imageLabel = emotesGui:FindFirstChildWhichIsA("ImageLabel")
		if not imageLabel then return nil end
	
		local spinButton = imageLabel:FindFirstChild("Spin")
		return spinButton
	end
	
	--// Function to handle Kills checking
	local function setupKillListener(spinButton)
		local leaderstats = player:FindFirstChild("leaderstats")
		if not leaderstats then
			warn("leaderstats not found for player!")
			return
		end
	
		local kills = leaderstats:FindFirstChild("Kills")
		if not kills then
			warn("Kills stat not found!")
			return
		end
	
		kills:GetPropertyChangedSignal("Value"):Connect(function()
			if spinButton and spinButton:IsA("TextButton") then
				-- Simulate clicking the Spin button
				spinButton:Activate()
				print("Spin button clicked automatically due to Kills change!")
			end
		end)
	end
	
	--// Main logic
	button.MouseButton1Click:Connect(function()
		local spinButton = getSpinButton()
		if spinButton then
			setupKillListener(spinButton)
			print("Spin listener setup complete!")
		else
			warn("Spin button not found! Make sure Emotes > ImageLabel > Spin exists.")
		end
	end)
	
end
